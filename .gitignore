.env
.history/
__pycache__/
*.py[cod]
.pytest_cache/
.coverage
htmlcov/
.venv/
venv/

# 本地运行数据库及 SQLite 辅助文件。
data/*.db
data/*.db-wal
data/*.db-shm

# 私钥和证书容器禁止进入版本库；公开证书链可以显式保留。
certs/*.key
certs/*.p12
certs/*.pfx
certs/*.pem
certs/*.csr
certs/*.crt
!certs/*_bundle.pem

launch/log/*
!launch/log/.gitkeep
launch/runtime/*
!launch/runtime/.gitkeep
