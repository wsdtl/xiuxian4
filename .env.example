# 项目基础配置。
PROJECT_NAME=xiuxian4
PROJECT_DEBUG=true
PROJECT_DOMAIN=
PROJECT_TIMEZONE=Asia/Shanghai

# HTTP 服务配置；公网回调通常监听 0.0.0.0。
SERVER_HOST=127.0.0.1
SERVER_PORT=8844
SERVER_RELOAD=false
SERVER_SSL_CERTFILE=
SERVER_SSL_KEYFILE=

# SQLite 持久化；相对路径以项目根目录为基准。
DATABASE_PATH=game/database/xiuxian4.db
DATABASE_BUSY_TIMEOUT_MS=5000

# 日志配置；协议联调时可临时改为 DEBUG。
LOG_LEVEL=INFO
LOG_COLOR=auto
LOG_DIR=launch/log
LOG_FILE=launch/log/runserver.log
LOG_ROTATION=12:00
LOG_RETENTION=14 days
LOG_COMPRESSION=zip

# 业务模块加载计划；列表内容必须是 Python 模块路径。
ROUTER_MODULE_GROUPS=["auto", "组件测试"]
ROUTER_MODULES=[]
ROUTER_FOLDERS=[]
ROUTER_GROUPS=["game.cmd"]
ROUTER_CHILD_FOLDERS=[]

# QQ 单机器人回调配置；生产环境必须开启签名校验。
QQ_EVENT_PATH=/qq/events
QQ_EVENT_SIGNATURE_REQUIRED=true
QQ_BOT_APP_ID=
QQ_BOT_SECRET=
