# 万象行纪本机配置模板。
# 复制为 .env 后填写真实值；.env 包含密钥和账号密码，不得提交到 Git。
# 所有相对路径都以项目根目录为基准，布尔值统一使用 true 或 false。

# =============================================================================
# 项目身份与公开地址
# =============================================================================
# PROJECT_NAME 同时参与本地驱动器租户身份，正式运行后不要随意修改。
PROJECT_NAME=xiuxian4
# 开启后 FastAPI 返回更多调试信息；公网生产环境建议设为 false。
PROJECT_DEBUG=true
# 对外生成网页、静态资源和战报链接时使用的完整站点地址。
# 可以填写 https://example.com，也可以省略协议写 example.com；留空时使用本机监听端口。
PROJECT_DOMAIN=
# 必须是有效 IANA 时区名，游戏周期、活动、日志展示和结算时间均以此为准。
PROJECT_TIMEZONE=Asia/Shanghai

# =============================================================================
# HTTP 服务与 TLS
# =============================================================================
# 仅本机访问使用 127.0.0.1；需要局域网、公网或 QQ 回调时通常使用 0.0.0.0。
SERVER_HOST=127.0.0.1
SERVER_PORT=8844
# 开发热重载会启动额外进程；正式运行和定时任务环境必须保持 false。
SERVER_RELOAD=false
# 由本进程直接终止 HTTPS 时填写证书链和私钥；由反向代理终止 TLS 时留空。
SERVER_SSL_CERTFILE=
SERVER_SSL_KEYFILE=

# =============================================================================
# SQLite 持久化
# =============================================================================
# 正式游戏权威数据库：账号、角色、资产、世界、行动、经济和战报等状态都在这里。
DATABASE_PATH=game/database/xiuxian4.db
# Web 游戏台独立短期消息流水库；可以单独清理，不能与正式游戏数据库填写同一路径。
MESSAGE_CONSOLE_DATABASE_PATH=game/database/message_console.db
# 两个 SQLite 数据库遇到写锁时的统一最长等待时间，单位为毫秒。
DATABASE_BUSY_TIMEOUT_MS=5000

# =============================================================================
# 账号身份安全
# =============================================================================
# 外部平台身份映射使用的 HMAC 密钥，至少 16 字节。
# 必须独立随机生成并长期保存；修改后旧平台身份将无法映射回原账号。
ACCOUNT_IDENTITY_SECRET=

# =============================================================================
# 日志
# =============================================================================
# 常规运行使用 INFO；协议联调时可以临时改为 DEBUG。
LOG_LEVEL=INFO
# auto 根据终端能力决定颜色，也可以填写 always 或 never。
LOG_COLOR=auto
LOG_DIR=launch/log
LOG_FILE=launch/log/runserver.log
# Loguru 轮转、保留和压缩规则。
LOG_ROTATION=12:00
LOG_RETENTION=14 days
LOG_COMPRESSION=zip

# =============================================================================
# 模块与路由加载
# =============================================================================
# 这些值必须是 Python 字符串列表。通常只调整列表内容，不修改加载器代码。
# MODULE_GROUPS：递归导入目录中的普通模块，例如 auto.cfg。
ROUTER_MODULE_GROUPS=["auto", "组件测试"]
# MODULES：导入指定普通模块；game.app 是正式游戏组合根。
ROUTER_MODULES=["game.app"]
# FOLDERS：导入自身直接暴露 APIRouter 的模块。
ROUTER_FOLDERS=[]
# GROUPS：导入自身带 APIRouter、子目录作为普通模块的模块组。
ROUTER_GROUPS=["game.cmd"]
# CHILD_FOLDERS：把指定目录下每个带 APIRouter 的子模块分别导入。
ROUTER_CHILD_FOLDERS=[]

# =============================================================================
# QQ 驱动器
# =============================================================================
# QQ 开放平台事件回调路径；平台侧回调地址需要与公开域名和此路径一致。
QQ_EVENT_PATH=/qq/events
# 公网生产环境必须为 true；只有隔离测试环境才允许临时关闭。
QQ_EVENT_SIGNATURE_REQUIRED=true
QQ_BOT_APP_ID=
QQ_BOT_SECRET=

# =============================================================================
# Web 游戏台
# =============================================================================
# 两项必须同时填写；任一项为空时 /game-console 保持关闭。
# 游戏台固定使用 local.message_console 身份，不要与 QQ 账号或机器人密钥复用。
WEB_CONSOLE_USERNAME=
WEB_CONSOLE_PASSWORD=

# =============================================================================
# 项目自定义扩展
# =============================================================================
# 未在 launch/config.py 登记的键会进入 config.custom，可按业务需要自行增加。
# 示例：MASTER_NAME=["示例维护者"]
